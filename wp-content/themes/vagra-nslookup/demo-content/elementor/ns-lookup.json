                        "id": "ns_faq_w",
                        "elType": "widget",
                        "widgetType": "vagra_nsl_faq_accordion",
                        "settings": {
                            "heading": "NS Lookup FAQ",
                            "faq_items": [
                                {
                                    "category": "",
                                    "question": "What is an NS lookup?",
                                    "answer": "An NS lookup queries the Domain Name System for the nameserver records of a domain — the servers responsible for answering DNS queries for that zone."
                                },
                                {
                                    "category": "",
                                    "question": "What are glue records?",
                                    "answer": "Glue records are A/AAAA records returned alongside NS records to prevent circular dependencies when the nameserver is within the same zone."
                                },
                                {
                                    "category": "",
                                    "question": "How many nameservers should a domain have?",
                                    "answer": "Best practice is at least two, ideally on different networks. Most registrars provide 2-4 nameservers."
                                },
                                {
                                    "category": "",
                                    "question": "Can I check nameservers for any domain?",
                                    "answer": "Yes. NS records are public DNS data. You can query nameservers for any registered domain."
                                },
                                {
                                    "category": "",
                                    "question": "What if no NS records are found?",
                                    "answer": "The domain may not be registered, or its zone may not be properly delegated. Check with the registrar."
                                }
                            ]
                        }
                    }
                ]
            }
        ]
    },
