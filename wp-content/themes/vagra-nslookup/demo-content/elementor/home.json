                        "elType": "widget",
                        "widgetType": "vagra_nsl_faq_accordion",
                        "settings": {
                            "heading": "Common questions",
                            "faq_items": [
                                {
                                    "category": "General",
                                    "question": "Is this really free?",
                                    "answer": "Yes. nslookup.am is free, open-source, and has no rate limits. No account needed."
                                },
                                {
                                    "category": "General",
                                    "question": "Do you log my queries?",
                                    "answer": "No. We don't store queries, results, or IP addresses. The tool runs in your browser."
                                },
                                {
                                    "category": "Technical",
                                    "question": "Which resolvers do you check?",
                                    "answer": "30+ public resolvers including Google, Cloudflare, Quad9, OpenDNS, and authoritative nameservers across 6 continents."
                                },
                                {
                                    "category": "Technical",
                                    "question": "Why don't my DNS changes show up?",
                                    "answer": "DNS propagation depends on TTL values. Changes can take minutes to 48 hours depending on the record's TTL and resolver caching."
                                },
                                {
                                    "category": "Technical",
                                    "question": "What record types are supported?",
                                    "answer": "A, AAAA, CNAME, MX, NS, TXT, SPF, DKIM, DMARC, SOA, PTR, CAA, and SRV — 13 types total."
                                }
                            ]
                        }
                    }
                ]
            }
        ]
