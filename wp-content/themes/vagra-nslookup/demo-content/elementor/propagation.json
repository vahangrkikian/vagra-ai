                        "elType": "widget",
                        "widgetType": "vagra_nsl_faq_accordion",
                        "settings": {
                            "heading": "Propagation FAQ",
                            "faq_items": [
                                {
                                    "category": "",
                                    "question": "How long does DNS propagation take?",
                                    "answer": "Typically 5 minutes to 48 hours, depending on the TTL of the old record and how aggressively resolvers cache."
                                },
                                {
                                    "category": "",
                                    "question": "Can I speed up propagation?",
                                    "answer": "Lower the TTL before making changes. Set it to 300 seconds (5 minutes) 24-48 hours before the change, then update the record."
                                },
                                {
                                    "category": "",
                                    "question": "Why do some resolvers show the old value?",
                                    "answer": "They cached the previous record and won't re-query until the TTL expires. Different resolvers have different cache durations."
                                },
                                {
                                    "category": "",
                                    "question": "What does 'propagation complete' mean?",
                                    "answer": "All queried resolvers return the same, expected value for the record. This means the new record has fully replaced the old one globally."
                                }
                            ]
                        }
                    }
                ]
            }
        ]
    },
